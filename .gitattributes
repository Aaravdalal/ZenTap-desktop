# Enforce LF line endings for all text files
# This prevents different OSes from flipping line endings and causing diff noise
* text=auto eol=lf

# Explicitly set common file types
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.cjs text eol=lf

# Mark binary files to prevent corruption
*.png binary
*.glb binary
*.glb filter=lfs diff=lfs merge=lfs -text
*.ico binary
